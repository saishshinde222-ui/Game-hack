# BytePlus Ark API key — used for both Seedream (images) and Seedance (video)
# Get your key at https://console.byteplus.com/ark/region:ark+ap-southeast-1/apikey
ARK_API_KEY=your_ark_api_key_here

# Server
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Godot WebSocket server (Godot listens, MCP connects)
GODOT_WS_URL=ws://localhost:9080
